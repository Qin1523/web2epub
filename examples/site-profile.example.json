{
  "name": "debug-python-docs-extreme",
  "match": ["docs.python.org"],
  "contentSelector": "div.body",
  "titleSelector": "h1",
  "removeSelectors": [
    ".related",
    ".sphinxsidebar",
    ".sphinxsidebarwrapper",
    ".footer",
    ".headerlink",
    ".admonition",
    ".highlight",
    ".highlight-python3",
    ".code-block-caption",
    ".toctree-wrapper",
    ".contents",
    ".table-of-contents",
    ".toc-backref",
    ".caption",
    ".figure",
    ".align-center",
    ".align-default",
    ".note",
    ".tip",
    ".warning",
    ".seealso",
    ".versionchanged",
    ".versionadded",
    ".deprecated",
    "nav",
    "footer",
    "aside",
    "form",
    "button",
    "img",
    "picture",
    "svg",
    "pre",
    "code",
    "table",
    "hr"
  ]
}