{
  "name": "web2epub",
  "version": "0.1.0",
  "description": "CLI for fetching web pages and packaging them as readable EPUB files.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "bin": {
    "web2epub": "./src/cli.js"
  },
  "scripts": {
    "setup": "npm install",
    "start": "node ./src/cli.js",
    "smoke": "node ./scripts/smoke.js"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "commander": "^14.0.0",
    "iconv-lite": "^0.7.0",
    "jschardet": "^3.1.4",
    "jsdom": "^26.1.0",
    "mime-types": "^3.0.1",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.2",
    "yazl": "^3.3.1"
  }
}
